# ============================================================
# Environment Variables Template
# Copy this file to .env and fill in the values
# ============================================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://admin:securepassword@localhost:5432/language_app
DIRECT_URL=postgresql://admin:securepassword@localhost:5432/language_app
POSTGRES_USER=admin
POSTGRES_PASSWORD=securepassword
POSTGRES_DB=language_app

# Redis (BullMQ Queue - Phase 30)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Application
NODE_ENV=development
PORT=3000
