generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Language {
  code       String  @id @db.Char(2)
  name       String  @db.VarChar(50)
  nativeName String  @map("native_name") @db.VarChar(50)
  flagEmoji  String  @map("flag_emoji") @db.VarChar(10)
  direction  String  @default("LTR") @db.VarChar(3)
  isActive   Boolean @default(true) @map("is_active")

  coursesLearning Course[] @relation("LearningLang")
  coursesTeaching Course[] @relation("FromLang")

  @@map("languages")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String    @unique @db.VarChar(30)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  totalXp      BigInt    @default(0) @map("total_xp")
  streakDays   Int       @default(0) @map("streak_days")
  lastActivity DateTime? @map("last_activity_date") @db.Date
  settings     Json      @default("{\"daily_goal\": 50, \"sound_effects\": true, \"notifications\": true}")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  enrollments        Enrollment[]
  vocabularyProgress UserVocabularyProgress[]
  inventory          UserInventory[]
  wallets            UserWallet[]
  leagueMemberships  LeagueMembership[]
  achievements       UserAchievement[]

  @@map("users")
}

model Course {
  id               BigInt   @id @default(autoincrement())
  learningLangCode String   @map("learning_lang_code") @db.Char(2)
  learningLang     Language @relation("LearningLang", fields: [learningLangCode], references: [code])
  fromLangCode     String   @map("from_lang_code") @db.Char(2)
  fromLang         Language @relation("FromLang", fields: [fromLangCode], references: [code])
  title            String   @db.VarChar(100)
  description      String?  @db.Text
  phase            String   @default("live") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  units              Unit[]
  enrollments        Enrollment[]
  vocabularyProgress UserVocabularyProgress[]

  @@unique([learningLangCode, fromLangCode], name: "uq_course_path")
  @@map("courses")
}

model Unit {
  id               BigInt  @id @default(autoincrement())
  courseId         BigInt  @map("course_id")
  course           Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  orderIndex       Int     @map("order_index")
  title            String  @db.VarChar(100)
  description      String? @db.Text
  guidebookContent Json?   @map("guidebook_content")
  colorTheme       String? @map("color_theme") @db.VarChar(7)
  iconUrl          String? @map("icon_url") @db.VarChar(255)

  levels Level[]

  @@unique([courseId, orderIndex], name: "uq_unit_order")
  @@map("units")
}

model Level {
  id            BigInt @id @default(autoincrement())
  unitId        BigInt @map("unit_id")
  unit          Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  orderIndex    Int    @map("order_index")
  totalLessons  Int    @default(5) @map("total_lessons")
  chestRewardId Int?   @map("chest_reward_id")

  exercises Exercise[]

  @@unique([unitId, orderIndex], name: "uq_level_order")
  @@map("levels")
}

model Exercise {
  id              BigInt   @id @default(autoincrement())
  levelId         BigInt   @map("level_id")
  level           Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  type            String   @db.VarChar(50)
  difficultyScore Int      @default(1) @map("difficulty_score") @db.SmallInt
  content         Json
  mediaMetadata   Json     @default("{}") @map("media_metadata")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([levelId])
  @@index([type])
  @@index([content], type: Gin)
  @@map("exercises")
}

model Enrollment {
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     BigInt   @map("course_id")
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  isActive     Boolean  @default(true) @map("is_active")
  progressData Json     @default("{}") @map("progress_data")
  enrolledAt   DateTime @default(now()) @map("enrolled_at") @db.Timestamptz

  @@id([userId, courseId])
  @@map("enrollments")
}

/// Partitioned by completed_at (Range Partitioning)
model LessonCompletion {
  id                 BigInt   @default(autoincrement())
  userId             String   @map("user_id") @db.Uuid
  courseId           BigInt   @map("course_id")
  unitId             BigInt   @map("unit_id")
  levelId            BigInt   @map("level_id")
  xpEarned           Int      @map("xp_earned")
  durationSeconds    Int      @map("duration_seconds")
  accuracyPercentage Decimal  @map("accuracy_percentage") @db.Decimal(5, 2)
  completedAt        DateTime @default(now()) @map("completed_at") @db.Timestamptz

  @@id([userId, completedAt, id])
  @@index([userId, courseId])
  @@map("lesson_completions")
}

/// SRS Algorithm Storage (FSRS / SM-2)
model UserVocabularyProgress {
  userId          String    @map("user_id") @db.Uuid
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        BigInt    @map("course_id")
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  wordToken       String    @map("word_token") @db.VarChar(100)
  stability       Float     @default(0) @map("stability")
  difficulty      Float     @default(0) @map("difficulty")
  repetitionCount Int       @default(0) @map("repetition_count")
  lastReviewedAt  DateTime? @default(now()) @map("last_reviewed_at") @db.Timestamptz
  nextReviewAt    DateTime  @map("next_review_at") @db.Timestamptz

  @@id([userId, courseId, wordToken])
  @@index([userId, courseId, nextReviewAt], name: "idx_srs_fetch_queue")
  @@map("user_vocabulary_progress")
}

model Item {
  id           Int     @id @default(autoincrement())
  name         String  @db.VarChar(100)
  type         String  @db.VarChar(50)
  costGems     Int     @map("cost_gems")
  isConsumable Boolean @default(false) @map("is_consumable")
  metadata     Json    @default("{}")

  inventoryRecords UserInventory[]

  @@map("items")
}

model UserInventory {
  id         BigInt   @id @default(autoincrement())
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId     Int      @map("item_id")
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  quantity   Int      @default(1)
  acquiredAt DateTime @default(now()) @map("acquired_at") @db.Timestamptz

  @@unique([userId, itemId], name: "uq_user_item")
  @@map("user_inventory")
}

enum Currency {
  GEMS
  HEARTS
}

model UserWallet {
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency  Currency
  balance   Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@id([userId, currency])
  @@map("user_wallets")
}

/// Partitioned Append-Only Audit Trail
model TransactionHistory {
  id              BigInt   @default(autoincrement())
  userId          String   @map("user_id") @db.Uuid
  currency        Currency
  amount          Int
  balanceAfter    Int      @map("balance_after")
  transactionType String   @map("transaction_type") @db.VarChar(50)
  referenceId     String?  @map("reference_id") @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([userId, createdAt, id])
  @@index([userId, createdAt(sort: Desc)])
  @@map("transaction_history")
}

model League {
  tier               Int    @id
  name               String @db.VarChar(50)
  promotionThreshold Int    @map("promotion_threshold")
  demotionThreshold  Int    @map("demotion_threshold")

  cohorts LeagueCohort[]

  @@map("leagues")
}

model LeagueCohort {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leagueTier    Int      @map("league_tier")
  league        League   @relation(fields: [leagueTier], references: [tier])
  weekStartDate DateTime @map("week_start_date") @db.Date
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  members LeagueMembership[]

  @@index([leagueTier, weekStartDate, isActive])
  @@map("league_cohorts")
}

model LeagueMembership {
  cohortId        String       @map("cohort_id") @db.Uuid
  cohort          LeagueCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId          String       @map("user_id") @db.Uuid
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentWeeklyXp Int          @default(0) @map("current_weekly_xp")
  joinedAt        DateTime     @default(now()) @map("joined_at") @db.Timestamptz

  @@id([cohortId, userId])
  @@index([cohortId, currentWeeklyXp(sort: Desc)], name: "idx_league_ranking")
  @@map("league_memberships")
}

model LootBox {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(100)
  costGems    Int     @map("cost_gems")
  description String? @db.VarChar(500)
  isActive    Boolean @default(true) @map("is_active")

  rates LootBoxRate[]

  @@map("loot_boxes")
}

model LootBoxRate {
  id        Int     @id @default(autoincrement())
  lootBoxId Int     @map("loot_box_id")
  lootBox   LootBox @relation(fields: [lootBoxId], references: [id], onDelete: Cascade)
  itemType  String  @map("item_type") @db.VarChar(50)
  itemValue String  @map("item_value") @db.VarChar(100)
  weight    Int
  isRare    Boolean @default(false) @map("is_rare")

  @@map("loot_box_rates")
}

model Achievement {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  tiers       Json
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  userProgress UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  userId          String      @map("user_id") @db.Uuid
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId   Int         @map("achievement_id")
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  currentProgress Int         @default(0) @map("current_progress")
  completedTier   Int         @default(0) @map("completed_tier")
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@id([userId, achievementId])
  @@map("user_achievements")
}
